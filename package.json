{
  "name": "flycore",
  "version": "1.0.0",
  "description": "一套整合业内主流技术栈、提供完整的开发工具链和最佳实践的现代化桌面应用研发模板",
  "author": {
    "name": "前端飞行手册",
    "email": "frontpilot@163.com",
    "url": "https://frontpilot.cn/"
  },
  "main": "dist-electron/main/index.js",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://frontpilot.cn/" ,
  "private": true,
  "keywords": [
    "electron",
    "vue",
    "vite",
    "element-plus",
    "bytenode",
    "unocss",
    "typescript",
    "template"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "npm run clean && vue-tsc && vite build && electron-builder -c electron.config.js && npm run copy-release-file",
    "build:encrypt": "npm run clean && vue-tsc && vite build && npm run generate-prod-entry && electron-builder -c electron.config.js && npm run copy-release-file",
    "build:custom": "electron-builder --win -c.nsis.script=build/scripts/installer.nsi",
    "release": "vue-tsc && vite build && electron-builder -c electron.config.js",
    "clean": "powershell -ExecutionPolicy Bypass -File build/scripts/Clean.ps1",
    "generate-prod-entry": "node build/scripts/generateProdEntry.js",
    "copy-release-file": "node build/scripts/copyReleaseFile.js",
    "preview": "vite preview",
    "clean-release": "rimraf release && rimraf dist && rimraf dist-electron",
    "clean-modules": "rimraf node_modules",
    "changelog": "conventional-changelog -p angular -i Changelog.md -s",
    "lint": "eslint 'src/**/*.{js,ts}' --fix",
    "mock-server": "node ./scripts/mock/mock-server.ts",
    "mock-update": "node scripts/mock/mockUpdate.ts",
    "mock-send": "node ./scripts/mock/mock-send.ts"
  },
  "dependencies": {
    "@vueuse/core": "^10.3.0",
    "bytenode": "^1.5.7",
    "echarts": "^5.4.3",
    "electron-store": "^8.1.0",
    "intro.js": "^7.2.0",
    "log4js": "^6.9.1",
    "mitt": "^3.0.0",
    "node-screenshots": "^0.2.1",
    "pinia-plugin-persistedstate": "^4.2.0",
    "quill": "^2.0.2",
    "three": "^0.172.0",
    "vue": "^3.2.47",
    "vue-i18n": "^9.2.2",
    "wallpaper": "^7.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.7.1",
    "@commitlint/config-conventional": "^17.7.0",
    "@typescript-eslint/eslint-plugin": "^6.5.0",
    "@typescript-eslint/parser": "^6.5.0",
    "@vitejs/plugin-vue": "^4.1.0",
    "axios": "^1.4.0",
    "conventional-changelog": "^5.0.0",
    "conventional-changelog-cli": "^4.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^24.4.0",
    "electron-updater": "^6.2.1",
    "element-plus": "^2.3.7",
    "eslint": "^8.48.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^9.17.0",
    "express": "^5.2.1",
    "pinia": "^3.0.4",
    "prettier": "^3.0.3",
    "rimraf": "^6.0.1",
    "sass": "^1.94.2",
    "typescript": "^5.0.2",
    "unocss": "^0.55.2",
    "unplugin-auto-import": "^0.16.4",
    "unplugin-vue-components": "^0.25.1",
    "vanilla-tilt": "^1.8.0",
    "vite": "^4.3.9",
    "vite-plugin-electron": "^0.12.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vue-router": "^4.2.2",
    "vue-tsc": "^2.2.8"
  },
  "engines": {
    "node": "20.9.0",
    "npm": ">=9.0.0"
  }
}
