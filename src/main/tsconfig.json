{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "outDir": "../dist/main",
        "lib": ["ES2020"],
        "types": ["node"],
        "module": "CommonJS",
        "moduleResolution": "node",
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": false,
        "rootDirs": ["."]
    },
    "include": [
        "./**/*.ts",
    ],
    "exclude": [
        "node_modules",
        "dist",
        "dist-electron",
    ],
    "references": [
        {
            "path": "../common"
        }
    ]
}