{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/common/*": ["src/common/*"],
      "@/main/*": ["src/main/*"],
      "@/renderer/*": ["src/renderer/*"]
    }
  }
}
